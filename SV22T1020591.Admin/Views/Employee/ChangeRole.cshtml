@{
    ViewBag.Title = "Phân quyền nhân viên";
    var roles = ViewBag.Roles as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var currentRoles = ViewBag.CurrentRoles as IEnumerable<string> ?? Enumerable.Empty<string>();
    var employeeId = ViewBag.EmployeeId ?? 0;
    var employeeName = ViewBag.EmployeeName ?? "";
}
@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-8">
        <div class="card card-primary card-outline">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check me-2"></i>
                    Phân quyền cho nhân viên
                </h5>

                <div class="text-end small">
                    <div>Đã cấp quyền:</div>
                    @if (currentRoles.Any())
                    {
                        foreach (var cr in currentRoles)
                        {
                            <span class="badge bg-success me-1">@cr</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Chưa có quyền</span>
                    }
                </div>
            </div>

            <div class="card-body">
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success">@TempData["Message"]</div>
                }
                <form id="formChangeRole" asp-action="ChangeRole" asp-controller="Employee" asp-route-id="@employeeId" method="post">
                    @Html.AntiForgeryToken()

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Mã nhân viên</dt>
                            <dd class="col-sm-9">@employeeId</dd>

                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@employeeName</dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-shield-lock me-1"></i>
                            Chọn quyền (có thể chọn nhiều)
                        </legend>

                        <div class="mb-3">
                            @foreach (var r in roles)
                            {
                                var isChecked = currentRoles.Contains(r.Value);
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="roles" value="@r.Value" id="role_@r.Value" @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="role_@r.Value">@r.Text</label>
                                </div>
                            }
                        </div>

                       
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>
