@model SV22T1020591.Models.Common.PagedResult<SV22T1020591.Models.Sales.OrderSearchInfo>
@{
    Layout = null;
    int stt = ((Model?.Page ?? 1) - 1) * (Model?.PageSize ?? 10);
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-bordered table-hover table-striped mb-0">
                <thead>
                    <tr>
                        <th style="width:80px">STT</th>
                        <th>Mã đơn</th>
                        <th>Ngày lập</th>
                        <th>Khách hàng</th>
                        <th>Trạng thái</th>
                        <th style="width:140px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.DataItems != null && Model.DataItems.Count > 0)
                    {
                        foreach (var order in Model.DataItems)
                        {
                            <tr>
                                <td>@(++stt)</td>
                                <td>@order.OrderID</td>
                                <td>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@order.CustomerName</td>
                                <td>@order.Status</td>
                                <td>
                                    <a href="~/Order/Detail/@order.OrderID" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="~/Order/Delete/@order.OrderID" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                Không có đơn hàng nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer d-flex justify-content-between align-items-center">
        <div>
            Có <strong>@(Model?.RowCount ?? 0)</strong> đơn hàng
        </div>

        @if (Model != null && Model.PageCount > 1)
        {
            <ul class="pagination pagination-sm mb-0">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.Page == 0)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                    else if (p.IsCurrent)
                    {
                        <li class="page-item active">
                            <span class="page-link">@p.Page</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="javascript:void(0)"
                               onclick="paginationSearch(null, document.getElementById('formSearch'), @p.Page)">
                                @p.Page
                            </a>
                        </li>
                    }
                }
            </ul>
        }
    </div>
</div>