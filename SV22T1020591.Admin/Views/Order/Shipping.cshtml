@{
    Layout = null;
    var orderId = ViewBag.OrderID ?? 0;
}
<form id="formShipping" action="@Url.Action("ShipConfirmed","Order")" method="post">
    <div class="modal-header text-bg-warning">
        <strong class="modal-title">Chuyển giao đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="mb-3">
            <label class="form-label">Chọn người giao hàng</label>
            <select id="shipperSelect" name="shipperID" class="form-select" asp-items="ViewBag.Shippers">
                <option value="">-- Chọn người giao --</option>
            </select>
        </div>

        <input type="hidden" id="shipOrderId" name="id" value="@orderId" />
        <div class="alert alert-secondary small">
            Sau khi xác nhận, đơn hàng sẽ chuyển sang trạng thái "Đang giao".
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-truck"></i> Chuyển giao
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>