@model SV22T1020591.Models.Catalog.Product
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

@{
    ViewData["Title"] = Model.ProductName;
    var photos = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Photo)) photos.Add(Model.Photo);
    if (ViewBag.Photos != null)
    {
        foreach (var p in ViewBag.Photos)
        {
            var fn = (p?.Photo as string) ?? "";
            if (!string.IsNullOrWhiteSpace(fn) && !photos.Contains(fn)) photos.Add(fn);
        }
    }

    string ResolveImageUrl(string fileName)
    {
        if (string.IsNullOrWhiteSpace(fileName))
            return Url.Content("~/images/products/placeholder.png");

        var physical = System.IO.Path.Combine(Env.WebRootPath ?? "", "images", "products", fileName);
        if (System.IO.File.Exists(physical))
            return Url.Content("~/images/products/" + fileName);

        if (fileName.StartsWith("http://") || fileName.StartsWith("https://") || fileName.StartsWith("/"))
            return fileName;

        return Url.Content("~/images/products/placeholder.png");
    }

    var mainImage = photos.FirstOrDefault() ?? Model.Photo ?? "";
    var mainImageUrl = ResolveImageUrl(mainImage);
    var descriptionHtml = string.IsNullOrWhiteSpace(Model.ProductDescription) ? "<em>Chưa có mô tả</em>" : Model.ProductDescription;
}

<div class="product-detail-container">
    <!-- Breadcrumb -->
    <div class="breadcrumb-wrapper">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
            </ol>
        </nav>
    </div>

    <div class="detail-grid">
        <!-- Left: Product Images -->
        <div class="detail-gallery">
            <div class="main-image-wrapper">
                <img id="mainImage" src="@mainImageUrl" alt="@Model.ProductName" class="main-product-image" />
            </div>

            @if (photos.Count > 1)
            {
                <div class="thumbnail-list">
                    @foreach (var ph in photos)
                    {
                        var thumb = ResolveImageUrl(ph);
                        <button type="button" class="thumbnail-btn" onclick="setMainImage('@thumb')">
                            <img src="@thumb" alt="Thumbnail" />
                        </button>
                    }
                </div>
            }
        </div>

        <!-- Right: Product Info -->
        <div class="detail-info">
            <h1 class="product-detail-title">@Model.ProductName</h1>

            <div class="product-meta-info">
                <span class="meta-item">
                    <i class="bi bi-building"></i> @Model.SupplierName
                </span>
                @if (!string.IsNullOrEmpty(Model.CategoryName))
                {
                    <span class="meta-item">
                        <i class="bi bi-tag"></i> @Model.CategoryName
                    </span>
                }
            </div>

            <div class="product-detail-price">
                @String.Format("{0:N0}₫", Model.Price)
            </div>

            <form id="addCartForm" class="add-to-cart-form">
                <input type="hidden" name="productID" value="@Model.ProductID" />

                <div class="quantity-selector">
                    <label class="quantity-label">Số lượng</label>
                    <div class="quantity-control">
                        <button type="button" class="qty-btn" onclick="changeQuantity(-1)">
                            <i class="bi bi-dash"></i>
                        </button>
                        <input type="number" name="quantity" id="quantity" value="1" min="1" class="quantity-input" readonly />
                        <button type="button" class="qty-btn" onclick="changeQuantity(1)">
                            <i class="bi bi-plus"></i>
                        </button>
                    </div>
                </div>

                <button id="btnAddCart" type="button" class="btn-add-to-cart" onclick="addToCartPage()">
                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                </button>
            </form>

            <div class="product-actions-extra">
                <a asp-controller="Product" asp-action="Index" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
                </a>
            </div>
        </div>
    </div>

    <!-- Product Attributes -->
    @if (ViewBag.Attributes != null && ((IEnumerable<dynamic>)ViewBag.Attributes).Any())
    {
        <div class="detail-section">
            <h3 class="section-title-custom">📋 Thông số kỹ thuật</h3>
            <div class="attributes-table-wrapper">
                <table class="attributes-table">
                    <tbody>
                        @foreach (var attr in ViewBag.Attributes)
                        {
                            <tr>
                                <td class="attr-name">@attr.AttributeName</td>
                                <td class="attr-value">@attr.AttributeValue</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Product Description -->
    <div class="detail-section">
        <h3 class="section-title-custom">📖 Mô tả sản phẩm</h3>
        <div class="product-description" id="productDescription">
            @Html.Raw(descriptionHtml)
        </div>
    </div>
</div>

<script>
    let currentQuantity = 1;

    function setMainImage(url) {
        const img = document.getElementById('mainImage');
        if (img) {
            img.src = url;
        }
    }

    function changeQuantity(delta) {
        const input = document.getElementById('quantity');
        let newVal = currentQuantity + delta;
        if (newVal < 1) newVal = 1;
        currentQuantity = newVal;
        input.value = currentQuantity;
    }

    // Renamed page-level function to avoid colliding with global window.addToCart
    async function addToCartPage() {
        const productID = document.querySelector('input[name="productID"]').value;
        const quantity = currentQuantity;
        const btn = document.getElementById('btnAddCart');

        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang thêm...';

        try {
            const data = await window.addToCart(productID, quantity);
            if (data && data.success) {
                showNotification('success', 'Đã thêm vào giỏ hàng!');
                const cartCount = document.getElementById('cartCount');
                if (cartCount && data.totalItems) {
                    cartCount.innerText = data.totalItems;
                }
            } else if (data && data.message) {
                showNotification('error', data.message);
            } else {
                showNotification('error', 'Có lỗi xảy ra. Vui lòng thử lại.');
            }
        } catch (err) {
            console.error(err);
            showNotification('error', 'Không thể thêm vào giỏ hàng.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng';
        }
    }

    function showNotification(type, message) {
        const notification = document.createElement('div');
        notification.className = `notification-toast ${type}`;
        notification.innerHTML = `
            <i class="bi ${type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill'}"></i>
            <span>${message}</span>
        `;

        document.body.appendChild(notification);

        setTimeout(() => {
            notification.style.animation = 'slideOut 0.3s ease';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    // Xử lý mô tả dài
    (function () {
        var el = document.getElementById('productDescription');
        if (!el) return;
        var maxHeight = 300;
        if (el.scrollHeight > maxHeight) {
            el.style.maxHeight = maxHeight + 'px';
            el.style.overflow = 'hidden';
            var btn = document.createElement('button');
            btn.className = 'btn-expand';
            btn.textContent = 'Xem thêm';
            btn.onclick = function () {
                if (el.style.maxHeight) {
                    el.style.maxHeight = '';
                    el.style.overflow = '';
                    btn.textContent = 'Thu gọn';
                } else {
                    el.style.maxHeight = maxHeight + 'px';
                    el.style.overflow = 'hidden';
                    btn.textContent = 'Xem thêm';
                }
            };
            el.parentNode.appendChild(btn);
        }
    })();
</script>